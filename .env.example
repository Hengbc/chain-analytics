# Chain-BD Environment Template
# Copy to .env and fill in your values

# ScyllaDB (DB)
SCYLLA_HOSTS=scylla
SCYLLA_PORT=9042
SCYLLA_KEYSPACE=chain_analytics

# Redis (Cache)
REDIS_URL=redis://redis:6379

# Node RPCs (Your nodes or Infura/Alchemy)
ETH_RPC_HTTP=http://localhost:8545
ETH_RPC_WS=ws://localhost:8546
BNB_RPC_HTTP=http://localhost:8545  # Adjust per chain
# ... Add for ARB, OP, etc. from chains.py

# Indexer
INDEXER_ENABLED_CHAINS=eth,bnb,arb,op,base,avax,xlayer,polygon,solana,btc

# API
SECRET_KEY=your-secret-key-change-this
DEBUG=True